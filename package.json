{
  "name": "predictionkit",
  "version": "0.0.0",
  "private": true,
  "description": "A developer toolkit for integrating prediction market data into React apps via one normalized API.",
  "license": "MIT",
  "author": "Jack Knoell",
  "repository": {
    "type": "git",
    "url": "https://github.com/predictionkit/predictionkit.git"
  },
  "homepage": "https://github.com/predictionkit/predictionkit#readme",
  "bugs": "https://github.com/predictionkit/predictionkit/issues",
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "smoke": "tsx scripts/smoke.ts",
    "storybook": "pnpm --filter @prediction-kit/react storybook",
    "changeset": "changeset",
    "version-packages": "changeset version && pnpm install --lockfile-only",
    "release": "turbo run build --filter=./packages/* && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.11",
    "@eslint/js": "^9.17.0",
    "@prediction-kit/core": "workspace:*",
    "@prediction-kit/react": "workspace:*",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1",
    "vitest": "^2.1.8"
  }
}
