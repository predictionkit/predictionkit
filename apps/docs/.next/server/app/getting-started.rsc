0:["tUYZXIz4-2zBmY_4FwV3D",[[["",{"children":["getting-started",{"children":["__PAGE__",{}]}]},"$undefined","$undefined",true],["",{"children":["getting-started",{"children":["__PAGE__",{},[["$L1",[["$","h1",null,{"children":"Getting Started"}],"\n",["$","p",null,{"children":["PredictionKit has two packages: ",["$","strong",null,{"children":["$","code",null,{"children":"@prediction-kit/core"}]}]," (the provider-agnostic SDK) and\n",["$","strong",null,{"children":["$","code",null,{"children":"@prediction-kit/react"}]}]," (headless components and hooks built on it)."]}],"\n",["$","h2",null,{"children":"Install"}],"\n",["$","pre",null,{"children":["$","code",null,{"className":"language-bash","children":"npm install @prediction-kit/core @prediction-kit/react react react-dom\n"}]}],"\n",["$","h2",null,{"children":"1. Create a client"}],"\n",["$","p",null,{"children":"A client is a set of providers. Reads fan out across all of them and merge by volume."}],"\n",["$","pre",null,{"children":["$","code",null,{"className":"language-ts","children":"import { createClient, polymarket, kalshi } from '@prediction-kit/core';\n\nconst client = createClient({ providers: [polymarket(), kalshi()] });\n\nconst trending = await client.getMarkets({ limit: 10 });\nconst one = await client.getMarket('polymarket:253591');\n"}]}],"\n",["$","p",null,{"children":"Every result is the same normalized shape:"}],"\n",["$","pre",null,{"children":["$","code",null,{"className":"language-ts","children":"interface Market {\n  id: string; // \"<source>:<nativeId>\"\n  source: 'polymarket' | 'kalshi';\n  title: string;\n  probability: number; // 0–1 (Yes outcome)\n  volume?: number;\n  status: 'open' | 'closed' | 'resolved';\n  endDate?: string;\n  url?: string;\n  outcomes?: { label: string; probability: number }[];\n}\n"}]}],"\n",["$","h2",null,{"children":"2. Add the React layer"}],"\n",["$","p",null,{"children":"Wrap your app in a provider, then use components or hooks."}],"\n",["$","pre",null,{"children":["$","code",null,{"className":"language-tsx","children":"import { PredictionKitProvider, TrendingMarkets } from '@prediction-kit/react';\nimport '@prediction-kit/react/styles.css'; // optional default theme\n\nexport function App() {\n  return (\n    <PredictionKitProvider client={client}>\n      <TrendingMarkets limit={10} />\n    </PredictionKitProvider>\n  );\n}\n"}]}],"\n",["$","p",null,{"children":"Prefer your own UI? Use the hooks instead:"}],"\n",["$","pre",null,{"children":["$","code",null,{"className":"language-tsx","children":"import { useTrendingMarkets } from '@prediction-kit/react';\n\nfunction MyWidget() {\n  const { data, loading, error } = useTrendingMarkets({ limit: 5 });\n  if (loading) return <Spinner />;\n  if (error) return <p>{error.message}</p>;\n  return <MyList markets={data} />;\n}\n"}]}],"\n",["$","h2",null,{"children":"3. Styling"}],"\n",["$","p",null,{"children":["Components are usable with ",["$","strong",null,{"children":"no CSS at all"}],". Opt into the default theme with the stylesheet import\nabove, override CSS variables, or target the stable ",["$","code",null,{"children":"pk-*"}]," classes."]}],"\n",["$","pre",null,{"children":["$","code",null,{"className":"language-css","children":":root {\n  --pk-accent: #7c3aed;\n  --pk-radius: 4px;\n}\n"}]}],"\n",["$","h2",null,{"children":"A note on the browser"}],"\n",["$","p",null,{"children":["Market-data reads need no auth. Polymarket allows browser requests; ",["$","strong",null,{"children":"Kalshi does not send CORS\nheaders"}],", so call it from a server (or a proxy route) when running client-side. See how the\n",["$","a",null,{"href":"/demo","children":"live demo"}]," does it."]}],"\n",["$","p",null,{"children":["Next: explore the ",["$","a",null,{"href":"/components","children":"components"}]," or read about the ",["$","a",null,{"href":"/providers","children":"providers"}],"."]}]],null],null],null]},[null,["$","$L2",null,{"parallelRouterKey":"children","segmentPath":["children",