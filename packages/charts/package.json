{
  "name": "@prediction-kit/charts",
  "version": "0.1.0",
  "description": "Recharts-based charts for prediction-market data, built on @prediction-kit/core and @prediction-kit/react.",
  "license": "MIT",
  "author": "Jack Knoell",
  "repository": {
    "type": "git",
    "url": "https://github.com/predictionkit/predictionkit.git",
    "directory": "packages/charts"
  },
  "homepage": "https://github.com/predictionkit/predictionkit/tree/main/packages/charts#readme",
  "bugs": "https://github.com/predictionkit/predictionkit/issues",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@prediction-kit/core": "workspace:^",
    "@prediction-kit/react": "workspace:^",
    "react": ">=18",
    "react-dom": ">=18",
    "recharts": ">=2.13"
  },
  "devDependencies": {
    "@prediction-kit/core": "workspace:*",
    "@prediction-kit/react": "workspace:*",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.0"
  },
  "keywords": [
    "prediction-market",
    "charts",
    "recharts",
    "react",
    "polymarket",
    "kalshi",
    "data-visualization"
  ]
}
