{
  "name": "@prediction-kit/core",
  "version": "0.2.0",
  "description": "Provider-agnostic SDK for prediction-market data (Polymarket, Kalshi) with one normalized model.",
  "license": "MIT",
  "author": "Jack Knoell",
  "repository": {
    "type": "git",
    "url": "https://github.com/predictionkit/predictionkit.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/predictionkit/predictionkit/tree/main/packages/core#readme",
  "bugs": "https://github.com/predictionkit/predictionkit/issues",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "prediction-market",
    "prediction-markets",
    "polymarket",
    "kalshi",
    "polymarket-api",
    "kalshi-api",
    "betting-odds",
    "forecasting",
    "sdk",
    "typescript"
  ]
}
